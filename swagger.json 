{
  "swagger": "2.0",
  "info": { 
    "title": "Blog API", 
    "version": "1.0.0" 
  },
  "paths": {
    "/api/articles": {
      "get": { 
        "summary": "Liste des articles", 
        "responses": { "200": { "description": "Succès" } } 
      },
      "post": {
        "summary": "Créer un article",
        "parameters": [
          { 
            "name": "article", 
            "in": "body", 
            "required": true, 
            "schema": { 
              "type": "object", 
              "properties": { 
                "titre": { "type": "string" }, 
                "contenu": { "type": "string" }, 
                "auteur": { "type": "string" } 
              } 
            } 
          }
        ],
        "responses": { "201": { "description": "Créé" } }
      }
    }
  }
}